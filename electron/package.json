{
  "name": "voice-time-manager",
  "version": "1.0.0",
  "description": "Track your time by speaking and plan your ideal day with voice commands",
  "main": "main.js",
  "homepage": "./",
  "author": {
    "name": "Voice Time Manager Team",
    "email": "support@voicetimemanager.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-repo/voice-time-manager.git"
  },
  "keywords": [
    "time-tracking",
    "voice-control",
    "productivity",
    "pwa",
    "electron"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "npm run build:win && npm run build:mac && npm run build:linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint .",
    "test": "jest"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "eslint": "^8.54.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "build": {
    "appId": "com.innovationgeneration.voicetimemanager",
    "productName": "Voice Time Manager",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "../index.html",
      "../manifest.json",
      "../sw.js",
      "../assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "../assets/icons/icon-256x256.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "../assets/icons/icon-512x512.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "rpm",
          "arch": ["x64"]
        }
      ],
      "icon": "../assets/icons/icon-512x512.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Voice Time Manager"
    },
    "dmg": {
      "title": "Voice Time Manager",
      "icon": "../assets/icons/icon-512x512.icns",
      "background": "../assets/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "publish": {
      "provider": "github",
      "owner": "your-username",
      "repo": "voice-time-manager"
    }
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
